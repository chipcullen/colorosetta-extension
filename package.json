{
  "name": "colorosetta",
  "displayName": "ColoRosetta",
  "description": "A one-to-many utility to translate colors",
  "publisher": "chipcullen",
  "version": "0.4.2",
  "repository": {
    "type": "git",
    "url": "https://github.com/chipcullen/colorosetta-extension.git"
  },
  "homepage": "https://github.com/chipcullen/colorosetta-extension/",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#555555",
    "theme": "dark"
  },
  "keywords": [
    "color",
    "colour",
    "translation",
    "color translation",
    "color spaces"
  ],
  "activationEvents": [
    "onCommand:colorosetta.translateColor",
    "onCommand:colorosetta.toHex6",
    "onCommand:colorosetta.toHex8",
    "onCommand:colorosetta.toRgb",
    "onCommand:colorosetta.toRgba",
    "onCommand:colorosetta.toHsl",
    "onCommand:colorosetta.toHsla",
    "onCommand:colorosetta.toLch",
    "onCommand:colorosetta.toOklch",
    "onCommand:colorosetta.toP3",
    "onCommand:colorosetta.toNamed"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "menus": {
      "commandPalette": [
        {
          "command": "colorosetta.translateColor",
          "title": "Translate Color",
          "category": "ColoRosetta",
          "when": "editorHasSelection"
        },
        {
          "command": "colorosetta.toHex6",
          "title": "Translate to Hex",
          "category": "ColoRosetta",
          "when": "editorHasSelection"
        },
        {
          "command": "colorosetta.toHex8",
          "title": "Translate to Hex 8",
          "category": "ColoRosetta",
          "when": "editorHasSelection"
        },
        {
          "command": "colorosetta.toRgb",
          "title": "Translate to RGB",
          "category": "ColoRosetta",
          "when": "editorHasSelection"
        },
        {
          "command": "colorosetta.toRgba",
          "title": "Translate to RGBa",
          "category": "ColoRosetta",
          "when": "editorHasSelection"
        },
        {
          "command": "colorosetta.toHsl",
          "title": "Translate to HSL",
          "category": "ColoRosetta",
          "when": "editorHasSelection"
        },
        {
          "command": "colorosetta.toHsla",
          "title": "Translate to HSLa",
          "category": "ColoRosetta",
          "when": "editorHasSelection"
        },
        {
          "command": "colorosetta.toLch",
          "title": "Translate to LCH",
          "category": "ColoRosetta",
          "when": "editorHasSelection"
        },
        {
          "command": "colorosetta.toOklch",
          "title": "Translate to OKLCH",
          "category": "ColoRosetta",
          "when": "editorHasSelection"
        },
        {
          "command": "colorosetta.toP3",
          "title": "Translate to Display P3",
          "category": "ColoRosetta",
          "when": "editorHasSelection"
        },
        {
          "command": "colorosetta.toNamed",
          "title": "Translate to Named",
          "category": "ColoRosetta",
          "when": "editorHasSelection"
        }
      ],
      "editor/context": [
        {
          "command": "colorosetta.translateColor",
          "title": "Translate Color",
          "category": "ColoRosetta",
          "when": "editorHasSelection"
        },
        {
          "command": "colorosetta.toHex6",
          "title": "Translate to Hex",
          "category": "ColoRosetta",
          "when": "editorHasSelection"
        },
        {
