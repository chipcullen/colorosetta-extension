          "when": "editorHasSelection"
        },
        {
          "command": "colorosetta.toRgba",
          "title": "Translate to RGBa",
          "category": "ColoRosetta",
          "when": "editorHasSelection"
        },
        {
          "command": "colorosetta.toHsl",
          "title": "Translate to HSL",
          "category": "ColoRosetta",
          "when": "editorHasSelection"
        },
        {
          "command": "colorosetta.toHsla",
